{
  "version": 2,
  "buildCommand": "npm run build --prefix Nutribowl/nutribowl-breakfast",
  "installCommand": "npm install --prefix Nutribowl/nutribowl-breakfast",
  "outputDirectory": "Nutribowl/nutribowl-breakfast/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
